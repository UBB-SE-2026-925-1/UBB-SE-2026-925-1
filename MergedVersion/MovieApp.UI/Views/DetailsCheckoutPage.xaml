<Page
    x:Class="MovieApp.UI.Views.DetailsCheckoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    xmlns:converters="using:MovieApp.UI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBool"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToVisibilityInverterConverter x:Key="BoolToVisibilityInverter"/>
        <converters:DateTimeFormatConverter x:Key="ScreeningTimeFormat" Format="ddd, dd MMM yyyy &#x2022; HH:mm"/>
        <converters:StringToImageSourceConverter x:Key="StringToImageSource"/>
    </Page.Resources>

    <ScrollViewer Padding="32" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="BackButton" Click="BackButton_Click" Content="Back"/>
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Details and Checkout" VerticalAlignment="Center"/>
            </StackPanel>

            <InfoBar
                IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource StringNotEmptyToBool}}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational"
                IsClosable="False"/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="16">

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="200" Height="300" CornerRadius="8" VerticalAlignment="Top">
                                <Image Source="{x:Bind ViewModel.Movie.PosterUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Movie.Title, Mode=OneWay}" TextWrapping="Wrap"/>
                                <TextBlock FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                           Text="{x:Bind ViewModel.Movie.Description, Mode=OneWay}"/>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Event" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.EventTitle, Mode=OneWay}"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Date and time" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.EventDateTimeDisplay, Mode=OneWay}"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Location" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.EventLocation, Mode=OneWay}"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Unit ticket price" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.UnitPriceDisplay, Mode=OneWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Available screenings"/>
                            <ComboBox x:Name="ScreeningCombo"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.Screenings, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedScreening, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Screening">
                                        <TextBlock Text="{x:Bind ScreeningTime, Converter={StaticResource ScreeningTimeFormat}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Select a screening to load its event details and seat capacity."/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Seats"/>
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Open the visual guide to pick your seats. Booked seats are shown grayed out and cannot be selected."/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="OpenSeatGuideButton"
                                        Click="OpenSeatGuide_Click"
                                        Content="Visual seat guide"
                                        IsEnabled="{x:Bind ViewModel.HasEvent, Mode=OneWay}"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Selected:"/>
                                    <Run Text="{x:Bind ViewModel.SelectedSeatCount, Mode=OneWay}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{x:Bind ViewModel.SeatCapacity, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Checkout"/>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Base price" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.BasePrice, Mode=OneWay}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Final price" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.FinalPrice, Mode=OneWay}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Apply free-enrollment reward"
                                      IsChecked="{x:Bind ViewModel.ApplyFreeEnrollment, Mode=TwoWay}"/>
                            <CheckBox Content="Apply trivia free-ticket reward"
                                      IsChecked="{x:Bind ViewModel.ApplyTriviaReward, Mode=TwoWay}"/>
                            <CheckBox IsChecked="{x:Bind ViewModel.ApplySlotMachineDiscount, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasSlotMachineDiscount, Mode=OneWay}">
                                <CheckBox.Content>
                                    <TextBlock>
                                        <Run Text="Apply slot-machine movie discount ("/>
                                        <Run Text="{x:Bind ViewModel.SlotMachineDiscountPercent, Mode=OneWay}"/>
                                        <Run Text="%)"/>
                                    </TextBlock>
                                </CheckBox.Content>
                            </CheckBox>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Referral code" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="Optional code"
                                             Text="{x:Bind ViewModel.ReferralCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="Validate" Click="ValidateReferral_Click"/>
                                </Grid>
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{x:Bind ViewModel.ReferralStatus, Mode=OneWay}"/>
                            </StackPanel>

                            <ToggleSwitch Header="Watch price"
                                          IsOn="{x:Bind ViewModel.IsWatchingPrice, Mode=OneWay}"
                                          Toggled="WatchPrice_Toggled"
                                          IsEnabled="{x:Bind ViewModel.HasEvent, Mode=OneWay}"/>

                            <Button Content="Confirm purchase"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="ConfirmPurchase_Click"
                                    IsEnabled="{x:Bind ViewModel.CanPurchase, Mode=OneWay}"/>

                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                       Visibility="{x:Bind ViewModel.HasUserJoined, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                       Text="You have already joined this event. Duplicate purchases are blocked."/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
