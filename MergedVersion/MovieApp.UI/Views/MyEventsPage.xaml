<Page
    x:Class="MovieApp.UI.Views.MyEventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:MovieApp.UI.Views"
    xmlns:ui="using:MovieApp.UI.Controls"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="20"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:EventSearchBox
                        PlaceholderText="Search my events by title or type"
                        SearchTextChanged="SearchBox_SearchTextChanged" />
                    <ui:EventSortSelector
                        Grid.Column="1"
                        PlaceholderText="Sort my events"
                        SelectedSortOption="{Binding EventListState.SelectedSortOption, Mode=OneWay}"
                        SortOptionChanged="SortSelector_SortOptionChanged" />
                    <ComboBox
                        Grid.Column="2"
                        PlaceholderText="Filter" />
                    <Button
                        Grid.Column="3"
                        Content="Reset" />
                </Grid>
            </Border>

            <controls:TabView>
                <controls:TabViewItem Header="Created">
                    <Grid
                        Padding="0,16,0,0"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <ListView Height="420"
                                      ItemsSource="{x:Bind ViewModel.VisibleEvents, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Event">
                                        <TextBlock Text="{x:Bind Title}" Padding="8" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBox Header="Title" Text="{x:Bind ViewModel.FormTitle, Mode=TwoWay}" />
                                <TextBox Header="Location" Text="{x:Bind ViewModel.FormLocation, Mode=TwoWay}" />
                                <controls:NumberBox Header="Price" Value="{x:Bind ViewModel.FormPrice, Mode=TwoWay}" />
                                <controls:NumberBox Header="Capacity" Value="{x:Bind ViewModel.FormCapacity, Mode=TwoWay}" />
                                <Button Content="Save" Command="{x:Bind ViewModel.SaveCreatedEventCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:TabViewItem>

                <controls:TabViewItem Header="Joined">
                    <Grid
                        Padding="0,16,0,0"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <ListView Height="420"
                                      ItemsSource="{x:Bind ViewModel.VisibleEvents, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Event">
                                        <TextBlock Text="{x:Bind Title}" Padding="8" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBox Header="Selected event" Text="{x:Bind ViewModel.SelectedEvent.Title, Mode=OneWay}" IsReadOnly="True" />
                                <TextBox
                                    AcceptsReturn="True"
                                    Header="Notes"
                                    Height="180"
                                    Text="{x:Bind ViewModel.FormNotes, Mode=TwoWay}" />
                                <Button Content="Cancel participation" Command="{x:Bind ViewModel.CancelParticipationCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:TabViewItem>

                <controls:TabViewItem Header="Favorites">
                    <Frame SourcePageType="views:FavoritesPage" />
                </controls:TabViewItem>

                <controls:TabViewItem Header="Manage">
                    <Grid
                        Padding="0,16,0,0"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <ListView Height="420"
                                      ItemsSource="{x:Bind ViewModel.VisibleEvents, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Event">
                                        <TextBlock Text="{x:Bind Title}" Padding="8" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBox Header="Title" Text="{x:Bind ViewModel.FormTitle, Mode=TwoWay}" />
                                <TextBox Header="Location" Text="{x:Bind ViewModel.FormLocation, Mode=TwoWay}" />
                                <TextBox Header="Type" Text="{x:Bind ViewModel.SelectedEvent.EventType, Mode=OneWay}" IsReadOnly="True" />
                                <Button Content="Edit" Command="{x:Bind ViewModel.SaveCreatedEventCommand}" />
                                <Button Content="Delete" Command="{x:Bind ViewModel.DeleteEventCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:TabViewItem>

                <controls:TabViewItem Header="Watchlist">
                    <Grid
                        Padding="0,16,0,0"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SurfaceCardStyle}">
                            <ListView Height="420"
                                      ItemsSource="{x:Bind ViewModel.WatchedEvents, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedWatchedEvent, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:WatchedEvent">
                                        <StackPanel Padding="8">
                                            <TextBlock Text="{x:Bind EventId.ToString()}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind EventTitle}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind TargetPrice.ToString()}" Foreground="Gray" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SurfaceCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBox Header="Event reference" Text="{x:Bind ViewModel.SelectedEventIdText, Mode=OneWay}" IsReadOnly="True" />
                                <controls:NumberBox Header="Target price" Value="{x:Bind ViewModel.SelectedTargetPrice, Mode=TwoWay}" />
                                <ToggleSwitch Header="Active" IsOn="True" />
                                <Button Content="Save" Click="WatchlistSaveButton_Click" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </controls:TabViewItem>
            </controls:TabView>
        </StackPanel>
    </ScrollViewer>
</Page>
