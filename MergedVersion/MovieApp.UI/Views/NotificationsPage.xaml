<Page
    x:Class="MovieApp.UI.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="16">

            <TextBlock
                Visibility="{x:Bind ViewModel.StatusVisibility, Mode=OneWay}"
                Style="{StaticResource SectionCaptionTextStyle}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <ListView
                        Height="480"
                        ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedNotification, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Notification">
                                <StackPanel Padding="0,6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Type}" />
                                    <TextBlock
                                        Text="{x:Bind Message}"
                                        TextWrapping="Wrap"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBox
                            Header="Type"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.SelectedNotification.Type, Mode=OneWay}" />

                        <!--
                            BUG FIX: previously bound to ViewModel.SelectedNotification.EventId (int),
                            which rendered "0" when no notification was selected because the int
                            default is 0, not an empty string. Now binds to SelectedEventIdText
                            which returns string.Empty when nothing is selected.
                        -->
                        <TextBox
                            Header="Event"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.SelectedEventIdText, Mode=OneWay}" />

                        <TextBox
                            AcceptsReturn="True"
                            Header="Message"
                            Height="220"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.SelectedNotification.Message, Mode=OneWay}" />

                        <Button
                            Command="{x:Bind ViewModel.MarkAsReadCommand}"
                            Content="Mark as read / Remove" />
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
