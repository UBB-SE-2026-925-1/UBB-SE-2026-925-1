<UserControl
    x:Class="MovieApp.UI.Views.ForumView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieApp.Core.Models"
    xmlns:converters="using:MovieApp.UI.Converters">

    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibility"/>
        
        <DataTemplate x:Key="ForumCommentTemplate" x:DataType="models:Comment">
            <StackPanel>
                <Border Padding="12" Margin="0,2"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold" FontSize="13">
                                <Run Text="User #"/>
                                <Run Text="{x:Bind AuthorDisplayId}"/>
                            </TextBlock>
                            <TextBlock Text=" • " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind CreatedAt}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>

                        <HyperlinkButton Content="Reply"
                                         FontSize="12"
                                         Tag="{x:Bind MessageId}"
                                         Click="ReplyButton_Click"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{x:Bind Replies}"
                              ItemTemplate="{StaticResource ForumCommentTemplate}"
                              Margin="24,6,0,0"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Movie Forum"
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Select a movie to view comments:" Margin="0,0,0,4"/>
            <ComboBox x:Name="ForumMovieSelector"
                      ItemsSource="{x:Bind ViewModel.Movies}"
                      DisplayMemberPath="Title"
                      SelectedItem="{x:Bind ViewModel.SelectedMovie, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     PlaceholderText="Add a comment (max 10000 chars)..."
                     Text="{x:Bind ViewModel.NewCommentContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxLength="10000"
                     Height="60" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Post Comment"
                    Command="{x:Bind ViewModel.AddCommentCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                   FontSize="12" Margin="0,68,0,0"/>

        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{x:Bind ViewModel.RootComments}"
                          ItemTemplate="{StaticResource ForumCommentTemplate}"/>
        </ScrollViewer>

        <Border Grid.Row="3" VerticalAlignment="Bottom"
                Visibility="{x:Bind ViewModel.ReplyToCommentId, Mode=OneWay, Converter={StaticResource IntToVisibility}}"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="12" Margin="0,0,0,4">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                        <Run Text="Replying to comment #"/>
                        <Run Text="{x:Bind ViewModel.ReplyToCommentId, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Grid.Column="1"
                            Content="Cancel"
                            Command="{x:Bind ViewModel.CancelReplyCommand}"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             PlaceholderText="Write your reply..."
                             Text="{x:Bind ViewModel.ReplyContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MaxLength="10000"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Send Reply"
                            Command="{x:Bind ViewModel.ReplyCommand}"
                            Style="{ThemeResource AccentButtonStyle}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
