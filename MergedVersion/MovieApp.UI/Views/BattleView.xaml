<UserControl
    x:Class="MovieApp.UI.Views.BattleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieApp.Core.Models"
    xmlns:movies="using:MovieApp.Core.Models"
    xmlns:converters="using:MovieApp.UI.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToVisibilityInverterConverter x:Key="BoolToVisibilityInverter"/>
        <converters:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBool"/>
    </UserControl.Resources>

    <Grid Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Center">

                <!-- Header -->
                <TextBlock Text="⚔️ Battle Arena"
                           FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock FontSize="14" Margin="0,0,0,20"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Your Points: "/>
                    <Run Text="{x:Bind ViewModel.TotalPoints, Mode=OneWay}" FontWeight="Bold"/>
                </TextBlock>

                <!-- DEMO CONTROLS -->
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="🛠 Demo:" VerticalAlignment="Center"
                                   FontWeight="SemiBold" FontSize="13"/>

                        <Button Content="⚡ End Battle Now"
                                Command="{x:Bind ViewModel.ForceSettleCommand}"
                                IsEnabled="{x:Bind ViewModel.IsBattleActive, Mode=OneWay}"
                                ToolTipService.ToolTip="Immediately settle the active battle and distribute points"/>

                        <Button Content="🔄 Reset Demo"
                                Command="{x:Bind ViewModel.ResetDemoCommand}"
                                ToolTipService.ToolTip="Delete all battles, refund frozen points, and create a new active battle"/>
                    </StackPanel>
                </Border>

                <!-- No Battle Message -->
                <Border Visibility="{x:Bind ViewModel.HasBattle, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverter}, FallbackValue=Visible}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12" Padding="40" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🏳️" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="No active battle this week"
                                   FontSize="18" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="Check back Monday for the next matchup! Or press Reset Demo above."
                                   FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Battle Cards -->
                <Grid Visibility="{x:Bind ViewModel.HasBattle, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                      Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- First Movie Card -->
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <Border CornerRadius="8" Width="120" Height="180" Margin="0,0,0,12">
                                <Image Source="{x:Bind ViewModel.ActiveBattle.FirstMovie.PosterUrl, Mode=OneWay}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.ActiveBattle.FirstMovie.Title, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="⭐" FontSize="16"/>
                                <TextBlock Text="{x:Bind ViewModel.ActiveBattle.FirstMovie.AverageRating, Mode=OneWay}"
                                           FontSize="20" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- VS -->
                    <TextBlock Grid.Column="1" Text="VS"
                               FontSize="28" FontWeight="ExtraBold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                    <!-- Second Movie Card -->
                    <Border Grid.Column="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <Border CornerRadius="8" Width="120" Height="180" Margin="0,0,0,12">
                                <Image Source="{x:Bind ViewModel.ActiveBattle.SecondMovie.PosterUrl, Mode=OneWay}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.ActiveBattle.SecondMovie.Title, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="⭐" FontSize="16"/>
                                <TextBlock Text="{x:Bind ViewModel.ActiveBattle.SecondMovie.AverageRating, Mode=OneWay}"
                                           FontSize="20" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- WINNER ANNOUNCEMENT -->
                <Border Visibility="{x:Bind ViewModel.IsBattleFinished, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="14" Padding="24,20" Margin="0,0,0,16"
                        HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="🏆 BATTLE RESULT"
                                   FontSize="12" FontWeight="SemiBold"
                                   CharacterSpacing="150"
                                   Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Winner:" FontSize="20" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.WinnerMovieName, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Winning bettors received 2× their points!"
                                   FontSize="12" Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <InfoBar x:Name="BattleStatusBar"
                         Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                         IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource StringNotEmptyToBool}}"
                         Severity="Informational"
                         Margin="0,0,0,12"/>

                <!-- Bet Section -->
                <StackPanel Visibility="{x:Bind ViewModel.HasBattle, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                    <!-- Battle ended notice -->
                    <Border Visibility="{x:Bind ViewModel.IsBattleFinished, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="⏰ This battle has ended — press Reset Demo to start a new one."
                                   FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <!-- Already bet notice -->
                    <TextBlock Visibility="{x:Bind ViewModel.HasBet, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                               Text="✅ You've already placed a bet — only one bet is allowed per battle."
                               FontSize="13" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <Button Content="🎲 Bet Now"
                            Command="{x:Bind ViewModel.ShowBetFormCommand}"
                            Visibility="{x:Bind ViewModel.CanBet, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12"
                            FontSize="16"/>

                    <!-- Bet Form -->
                    <Border Visibility="{x:Bind ViewModel.ShowBetForm, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Place Your Bet" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Select Movie:" Margin="0,0,0,4"/>
                            <ComboBox x:Name="BetMovieSelector"
                                      ItemsSource="{x:Bind ViewModel.BetMovieOptions}"
                                      DisplayMemberPath="Title"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,0,12"
                                      SelectionChanged="BetMovieSelector_SelectionChanged"/>

                            <TextBlock Text="Points to Bet:" Margin="0,0,0,4"/>
                            <NumberBox Value="{x:Bind ViewModel.BetAmount, Mode=TwoWay}"
                                       Minimum="1" SpinButtonPlacementMode="Compact"
                                       Margin="0,0,0,12"/>

                            <Button Content="Confirm Bet"
                                    Command="{x:Bind ViewModel.PlaceBetCommand}"
                                    Style="{ThemeResource AccentButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Existing Bet Info -->
                    <Border Visibility="{x:Bind ViewModel.HasBet, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Your Active Bet" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,8,0,0">
                                <Run Text="Movie: "/>
                                <Run Text="{x:Bind ViewModel.UserBet.Movie.Title, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Amount: "/>
                                <Run Text="{x:Bind ViewModel.UserBet.Amount, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text=" points"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
