<Window
    x:Class="MovieApp.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:MovieApp.UI.Views"
    Title="MovieApp Unified">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <controls:NavigationView
            x:Name="AppNavigationView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            PaneDisplayMode="Left"
            SelectionChanged="AppNavigationView_SelectionChanged">
            
            <controls:NavigationView.MenuItems>
                <controls:NavigationViewItem Content="Catalog" Tag="Catalog" Icon="AllApps"/>
                <controls:NavigationViewItem Content="Battle Arena" Tag="Battle">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE1AD;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
                <controls:NavigationViewItem Content="Forum" Tag="Forum" Icon="Message"/>
                <controls:NavigationViewItem Content="Profile" Tag="Profile" Icon="Contact"/>

                <controls:NavigationViewItemSeparator/>
                <controls:NavigationViewItem Content="Home" Tag="Home" Icon="Home"/>
                <controls:NavigationViewItem Content="Favorites" Tag="Favorites" Icon="Favorite"/>
                <controls:NavigationViewItem Content="My Events" Tag="MyEvents" Icon="Calendar"/>
                <controls:NavigationViewItem Content="Slots" Tag="SlotMachine" Icon="Shop"/>
                <controls:NavigationViewItem Content="Trivia Wheel" Tag="TriviaWheel" Icon="Help"/>
            </controls:NavigationView.MenuItems>

            <controls:NavigationView.FooterMenuItems>
                <controls:NavigationViewItem Content="Notifications" Tag="Notifications">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE1CE;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
                <controls:NavigationViewItem Content="Rewards" Tag="Rewards">
                    <controls:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A1;" />
                    </controls:NavigationViewItem.Icon>
                </controls:NavigationViewItem>
            </controls:NavigationView.FooterMenuItems>

            <Grid>
                <!-- Content Frame for Navigation -->
                <Frame x:Name="ContentFrame" />
                
                <!-- Movie Detail Overlay (for seamless detail transitions like Team B) -->
                <Grid x:Name="MovieDetailOverlay" Visibility="Collapsed" Canvas.ZIndex="10" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                    <views:MovieDetailView x:Name="MovieDetailViewControl" />
                </Grid>
            </Grid>
        </controls:NavigationView>
    </Grid>
</Window>
