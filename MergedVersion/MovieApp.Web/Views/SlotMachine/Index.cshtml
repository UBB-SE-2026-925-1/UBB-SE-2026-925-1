@model SlotMachineIndexViewModel
@{
    ViewData["Title"] = "Slot Machine";
}

<style>
    .reel {
        background: #111;
        color: #f1c40f;
        border-radius: .75rem;
        padding: 1.5rem 1rem;
        text-align: center;
        font-family: "Georgia", serif;
        min-height: 6rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: inset 0 0 12px rgba(0,0,0,.6);
    }

    .reel-label {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .15rem;
        color: #aaa;
    }

    .reel-value {
        font-size: 1.5rem;
        font-weight: bold;
        margin-top: .35rem;
        animation: pulse .8s ease-out;
    }

    @@keyframes pulse {
        0%   { transform: scale(.85); opacity: 0; }
        60%  { transform: scale(1.08); opacity: 1; }
        100% { transform: scale(1); }
    }

    .jackpot-badge {
        background: linear-gradient(90deg, #f7b733, #fc4a1a);
        color: white;
        padding: .5rem 1rem;
        border-radius: 999px;
        font-weight: bold;
        display: inline-block;
    }
</style>

@* -- Header ---------------------------------------------------------------- *@
<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="mb-1">Slot Machine</h1>
        <p class="text-muted mb-0">Spin the reels for a chance to win movie discounts.</p>
    </div>
    <div class="text-end">
        <div class="badge bg-primary fs-6">@Model.AvailableSpins spin(s) available</div>
        <div class="small text-muted mt-1">
            Daily: @Model.DailySpinsRemaining | Bonus: @Model.BonusSpins | Streak: @Model.LoginStreak
        </div>
    </div>
</div>

@* -- Status message -------------------------------------------------------- *@
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.LastResult?.JackpotDiscountApplied == true ? "alert-success" : "alert-info")">
        @Model.StatusMessage
    </div>
}

@* -- Reels ----------------------------------------------------------------- *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="reel">
            <span class="reel-label">Genre</span>
            <span class="reel-value">
                @(Model.LastResult?.Genre?.Name ?? "-")
            </span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="reel">
            <span class="reel-label">Actor</span>
            <span class="reel-value">
                @(Model.LastResult?.Actor?.Name ?? "-")
            </span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="reel">
            <span class="reel-label">Director</span>
            <span class="reel-value">
                @(Model.LastResult?.Director?.Name ?? "-")
            </span>
        </div>
    </div>
</div>

@* -- Spin button ----------------------------------------------------------- *@
<form asp-action="Spin" method="post" class="text-center mb-4">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-lg btn-warning px-5" @(Model.CanSpin ? "" : "disabled")>
        @(Model.CanSpin ? "Spin!" : "No spins remaining")
    </button>
</form>

@* -- Result --------------------------------------------------------------- *@
@if (Model.LastResult is not null)
{
    if (Model.LastResult.JackpotDiscountApplied && Model.LastResult.JackpotMovie is not null)
    {
        <div class="card mb-4 border-warning">
            <div class="card-body text-center">
                <div class="jackpot-badge mb-3">JACKPOT</div>
                <h3>@Model.LastResult.JackpotMovie.Title</h3>
                <p class="lead text-muted">
                    You won a <strong>@Model.LastResult.DiscountPercentage%</strong> discount on this movie!
                </p>
            </div>
        </div>
    }

    if (Model.LastResult.MatchingEvents.Any())
    {
        <h5>Matching screenings</h5>
        <div class="list-group">
            @foreach (var ev in Model.LastResult.MatchingEvents)
            {
                var isJackpotEvent = Model.LastResult.JackpotEventIds.Contains(ev.Id);
                <div class="list-group-item d-flex justify-content-between align-items-center @(isJackpotEvent ? "list-group-item-warning" : "")">
                    <div>
                        <div class="fw-bold">@ev.Title</div>
                        <div class="small text-muted">@ev.EventDateTime.ToString("MMM dd, yyyy HH:mm")</div>
                    </div>
                    @if (isJackpotEvent)
                    {
                        <span class="badge bg-warning text-dark">Jackpot</span>
                    }
                </div>
            }
        </div>
    }
    else if (!Model.LastResult.JackpotDiscountApplied)
    {
        <div class="text-center text-muted">No events match this reel combination.</div>
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('.reel-value').forEach(el => {
            el.style.animation = 'none';
            void el.offsetWidth;
            el.style.animation = '';
        });
    </script>
}
