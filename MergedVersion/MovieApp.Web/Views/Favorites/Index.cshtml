@model MovieApp.Web.Models.FavoriteIndexViewModel
@{
    ViewData["Title"] = "Favorites";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h2 mb-0 fw-bold">My Favorite Events</h1>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (Model.Events.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <h4 class="mt-3">No favorites yet</h4>
        <p>Add events to your favorites from the Events page.</p>
        <a href="/Events" class="btn btn-outline-primary mt-2">Browse Events</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var ev in Model.Events)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(ev.PosterUrl))
                    {
                        <div class="ratio ratio-16x9 overflow-hidden" style="border-radius: .375rem .375rem 0 0;">
                            <img src="@ev.PosterUrl" alt="@ev.Title poster"
                                 class="card-img-top object-fit-cover" loading="lazy"
                                 onerror="this.onerror=null;this.parentElement.style.display='none';" />
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-1">@ev.Title</h5>

                        <div class="mb-2">
                            @if (!string.IsNullOrWhiteSpace(ev.EventType))
                            {
                                <span class="badge bg-secondary me-1">@ev.EventType</span>
                            }
                            @if (ev.EventDateTime > DateTime.Now)
                            {
                                <span class="badge bg-success">Upcoming</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted">Past</span>
                            }
                        </div>

                        <p class="card-text small text-muted mb-1">
                            <strong>When:</strong> @ev.EventDateTime.ToString("yyyy-MM-dd HH:mm")
                        </p>
                        <p class="card-text small text-muted mb-1">
                            <strong>Where:</strong> @ev.LocationReference
                        </p>
                        <p class="card-text small text-muted mb-2">
                            <strong>Price:</strong> @ev.TicketPrice.ToString("C")
                        </p>

                        @if (!string.IsNullOrWhiteSpace(ev.Description))
                        {
                            <p class="card-text small text-muted lh-sm flex-grow-1" style="
                                display:-webkit-box;
                                -webkit-line-clamp:3;
                                -webkit-box-orient:vertical;
                                overflow:hidden;">
                                @ev.Description
                            </p>
                        }

                        <form asp-action="Remove" asp-controller="Favorites" method="post" class="mt-auto">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="EventId" value="@ev.Id" />
                            <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                            <button type="submit" class="btn btn-outline-danger w-100">
                                Remove from Favorites
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <style>
        .object-fit-cover { object-fit: cover; width: 100%; height: 100%; }
    </style>
}
