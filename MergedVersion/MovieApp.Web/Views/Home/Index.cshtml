@{
    ViewData["Title"] = "Home";
}

<div class="py-5">
    @* -- Hero Section -- *@
    <div class="row align-items-center g-5 py-5 mb-5">
        <div class="col-lg-7 text-center text-lg-start">
            <h1 class="display-3 fw-bold lh-1 mb-3 bg-gradient text-primary" style="background: linear-gradient(45deg, #0d6efd, #0dcaf0); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Experience Movies Like Never Before
            </h1>
            <p class="col-lg-10 fs-4 text-muted">
                Your ultimate destination for movie discovery, fan battles, and exclusive community events. Dive into the world of cinema with a touch of gamification.
            </p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                <a href="/Catalog" class="btn btn-primary btn-lg px-4 me-md-2 fw-bold shadow-sm">Explore Catalog</a>
                <a href="/Battle" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">Enter Battle Arena</a>
            </div>
        </div>
        <div class="col-lg-5 d-none d-lg-block text-center">
            <div class="bg-dark p-4 rounded-4 shadow-lg rotate-3d" style="transform: perspective(1000px) rotateY(-15deg) rotateX(10deg);">
                <img src="https://images.unsplash.com/photo-1485846234645-a62644f84728?auto=format&fit=crop&q=80&w=800" 
                     class="img-fluid rounded-3 shadow" alt="Cinema" />
            </div>
        </div>
    </div>

    @* -- Features Section -- *@
    <div class="row g-4 py-5 row-cols-1 row-cols-md-3">
        <div class="col">
            <div class="card h-100 border-0 shadow-sm p-4 text-center hover-lift">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-2 mb-3 rounded-circle mx-auto" style="width: 64px; height: 64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 1a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V1zm4 0v6h8V1H4zm8 8H4v6h8V9z"/>
                    </svg>
                </div>
                <h3 class="fs-4 fw-bold">Rich Catalog</h3>
                <p class="text-muted">Explore thousands of movies with detailed metadata, critic scores, and user reviews.</p>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-0 shadow-sm p-4 text-center hover-lift">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-danger bg-gradient fs-2 mb-3 rounded-circle mx-auto" style="width: 64px; height: 64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zM4.5 7.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/>
                    </svg>
                </div>
                <h3 class="fs-4 fw-bold">Gamified Fun</h3>
                <p class="text-muted">Win rewards in the Battle Arena, spin the Slot Machine, and test your knowledge in Trivia.</p>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-0 shadow-sm p-4 text-center hover-lift">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-success bg-gradient fs-2 mb-3 rounded-circle mx-auto" style="width: 64px; height: 64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                    </svg>
                </div>
                <h3 class="fs-4 fw-bold">Community Events</h3>
                <p class="text-muted">Join exclusive screenings and community events to watch your favorite films with others.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .bg-gradient {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0));
    }
</style>
}
