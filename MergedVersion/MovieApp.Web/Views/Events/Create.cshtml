@model MovieApp.Web.Models.EventCreateInputModel
@{
    ViewData["Title"] = "Create event";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
        </svg>
        Back to events
    </a>
</div>

<h1 class="h4 mb-3">Create event</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small d-none-empty"></div>

            <div class="row g-3">
                <div class="col-12 col-md-8">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="EventType" class="form-label"></label>
                    <select asp-for="EventType" class="form-select">
                        <option value="">-- choose --</option>
                        @foreach (var t in MovieApp.Web.Models.EventCreateInputModel.EventTypeChoices)
                        {
                            <option value="@t" selected="@(Model.EventType == t)">@t</option>
                        }
                    </select>
                    <span asp-validation-for="EventType" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="EventDateTime" class="form-label"></label>
                    <input asp-for="EventDateTime" type="datetime-local" class="form-control" value="@Model.EventDateTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="EventDateTime" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" autocomplete="off" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>

                <div class="col-6 col-md-3">
                    <label asp-for="TicketPrice" class="form-label"></label>
                    <input asp-for="TicketPrice" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="TicketPrice" class="text-danger small"></span>
                </div>
                <div class="col-6 col-md-3">
                    <label asp-for="MaxCapacity" class="form-label"></label>
                    <input asp-for="MaxCapacity" type="number" min="1" class="form-control" />
                    <span asp-validation-for="MaxCapacity" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="PosterUrl" class="form-label"></label>
                    <input asp-for="PosterUrl" class="form-control" placeholder="https://…" />
                    <span asp-validation-for="PosterUrl" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">Cancel</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Create event</button>
            </div>
        </form>
    </div>
</div>

