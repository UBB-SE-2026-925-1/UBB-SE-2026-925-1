@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div class="mb-4" style="font-size:5rem;line-height:1;">&#128561;</div>
    <h1 class="display-4 fw-bold text-danger mb-2">Something went wrong</h1>
    <p class="lead text-muted mb-4">An unexpected error occurred. Please try again later.</p>
    <div class="d-flex justify-content-center gap-2">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">Go Back</a>
        <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
</div>
