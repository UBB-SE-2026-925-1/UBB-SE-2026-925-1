@{
    ViewData["Title"] = "Page Not Found";
    Context.Response.StatusCode = 404;
}

<div class="text-center py-5">
    <div class="mb-3" style="font-size:5rem;line-height:1;">&#127910;</div>
    <h1 class="display-1 fw-bold text-muted">404</h1>
    <h2 class="mb-2">Page Not Found</h2>
    <p class="lead text-muted mb-4">The page you're looking for doesn't exist or has been moved.</p>
    <div class="d-flex justify-content-center gap-2">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">Go Back</a>
        <a href="/Catalog" class="btn btn-primary">Browse Movies</a>
    </div>
</div>
