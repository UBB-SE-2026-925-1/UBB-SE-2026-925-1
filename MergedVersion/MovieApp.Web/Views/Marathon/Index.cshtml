@model MovieApp.Web.Models.MarathonIndexViewModel
@{
    ViewData["Title"] = "Marathons";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h2 mb-0 fw-bold">This Week's Marathons</h1>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (Model.Items.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <h4 class="mt-3">No marathons available this week</h4>
        <p>Check back later.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(item.Marathon.PosterUrl))
                    {
                        <div class="ratio ratio-16x9 overflow-hidden" style="border-radius: .375rem .375rem 0 0;">
                            <img src="@item.Marathon.PosterUrl" alt="@item.Marathon.Title poster"
                                 class="card-img-top object-fit-cover" loading="lazy"
                                 onerror="this.onerror=null;this.parentElement.style.display='none';" />
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-1">@item.Marathon.Title</h5>
                        @if (!string.IsNullOrWhiteSpace(item.Marathon.Theme))
                        {
                            <span class="badge bg-secondary mb-2 align-self-start">@item.Marathon.Theme</span>
                        }
                        @if (item.Marathon.IsElite)
                        {
                            <span class="badge bg-warning text-dark mb-2 align-self-start">Elite</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Marathon.Description))
                        {
                            <p class="card-text small text-muted">@item.Marathon.Description</p>
                        }

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Progress</span>
                                <span>@item.CompletedMovies / @item.TotalMovies movies</span>
                            </div>
                            <div class="progress mb-2" role="progressbar"
                                 aria-valuenow="@item.ProgressPercent" aria-valuemin="0" aria-valuemax="100"
                                 style="height: 10px;">
                                <div class="progress-bar @(item.IsJoined ? "bg-success" : "bg-secondary")"
                                     style="width: @item.ProgressPercent%"></div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center small text-muted mb-3">
                                <span>@item.ParticipantCount participant@(item.ParticipantCount == 1 ? "" : "s")</span>
                                @if (item.IsJoined)
                                {
                                    <span class="badge bg-success">Joined</span>
                                }
                            </div>

                            <a href="@Url.Action("Details", "Marathon", new { id = item.Marathon.Id })"
                               class="btn btn-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <style>
        .object-fit-cover { object-fit: cover; width: 100%; height: 100%; }
    </style>
}
