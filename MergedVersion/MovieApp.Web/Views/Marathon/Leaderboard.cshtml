@model MovieApp.Web.Models.MarathonLeaderboardViewModel
@{
    ViewData["Title"] = $"{Model.Marathon.Title} — Leaderboard";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Marathon")">Marathons</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Details", "Marathon", new { id = Model.Marathon.Id })">@Model.Marathon.Title</a></li>
        <li class="breadcrumb-item active">Leaderboard</li>
    </ol>
</nav>

<h1 class="h2 fw-bold mb-3">@Model.Marathon.Title — Leaderboard</h1>

@if (Model.Leaderboard.Count == 0)
{
    <p class="text-muted">No participants yet.</p>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>User</th>
                        <th class="text-end">Movies Completed</th>
                        <th class="text-end">Trivia Accuracy</th>
                        <th class="text-end">Finished At</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var entry in Model.Leaderboard)
                    {
                        <tr>
                            <td>@rank</td>
                            <td>@entry.Username</td>
                            <td class="text-end">@entry.CompletedMoviesCount</td>
                            <td class="text-end">@entry.TriviaAccuracy.ToString("F1")%</td>
                            <td class="text-end">
                                @(entry.FinishedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
